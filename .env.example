# X Layer Testnet; never place private keys in this file.
X_LAYER_RPC_URL=https://testrpc.xlayer.tech/terigon
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000

# Values printed after script/00_DeployTestnetV4.s.sol runs.
# X Layer Testnet already has this Hookmate Permit2 bytecode; the script reuses it.
PERMIT2=0x3191Fc1E303EF4e12a7DE5f5d2e8d53A0660c5b9
POOL_MANAGER=0x0000000000000000000000000000000000000000
POSITION_MANAGER=0x0000000000000000000000000000000000000000
STATE_VIEW=0x0000000000000000000000000000000000000000
DEMO_ROUTER=0x0000000000000000000000000000000000000000

# Values printed after the token, Hook, and pool scripts run.
TOKEN_A=0x0000000000000000000000000000000000000000
TOKEN_B=0x0000000000000000000000000000000000000000
HOOK_ADDRESS=0x0000000000000000000000000000000000000000

# Default demo sizing: 1,000,000 tokens issued, 100e18 initial liquidity.
INITIAL_SUPPLY=1000000000000000000000000
INITIAL_LIQUIDITY=100000000000000000000

# For command-line demo buys, set INPUT_TOKEN to the deployed mUSDC address.
INPUT_TOKEN=0x0000000000000000000000000000000000000000
SWAP_AMOUNT=100000000000000000
