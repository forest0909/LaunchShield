# X Layer Mainnet; never place private keys in this file.
X_LAYER_RPC_URL=https://rpc.xlayer.tech
DEPLOYER_ADDRESS=0x0000000000000000000000000000000000000000

# Values printed after the deployment scripts run.
TOKEN_A=0x0000000000000000000000000000000000000000
TOKEN_B=0x0000000000000000000000000000000000000000
HOOK_ADDRESS=0x0000000000000000000000000000000000000000

# A deterministic Hookmate simple router already verified on X Layer.
DEMO_ROUTER=0xE4e6CAdE3E2a67F16A5d867C44e1e7Df02f0fc03

# Default demo sizing: 1,000,000 tokens issued, 100e18 initial liquidity.
INITIAL_SUPPLY=1000000000000000000000000
INITIAL_LIQUIDITY=100000000000000000000

# For command-line demo buys, set INPUT_TOKEN to the deployed mUSDC address.
INPUT_TOKEN=0x0000000000000000000000000000000000000000
SWAP_AMOUNT=100000000000000000
